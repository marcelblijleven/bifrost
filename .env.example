HTTP_ADDR=:8080
DATABASE_URL=postgres://bifrost:bifrost@localhost:5432/bifrost?sslmode=disable
API_KEY=change-me-in-production
JWT_SECRET=change-me-min-32-chars-random-string

# Public URL — the externally reachable URL of this Bifrost instance (no trailing slash).
# Required for the "Install webhook" feature. Providers send webhook events to <PUBLIC_URL>/webhooks/<provider>.
PUBLIC_URL=https://bifrost.example.com

# Single-port mode (optional): URL of the SvelteKit SSR server. When set, the
# Go server reverse-proxies all non-API paths there and serves the API under
# /api only, so one port serves UI, API, and webhooks. Leave empty for the
# split deployment (external proxy routes to :8080 and :3000 separately).
FRONTEND_URL=

# GitHub auth — App credentials take priority over token when both are set.

# Option A: GitHub App (recommended)
GITHUB_APP_ID=
GITHUB_INSTALLATION_ID=
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
...
-----END RSA PRIVATE KEY-----"

# Option B: Personal access token
GITHUB_TOKEN=

# GitHub Enterprise — optional; leave empty for github.com
# GHES example:  GITHUB_BASE_URL=https://github.company.com/api/v3/
# EU cloud:      GITHUB_BASE_URL=https://api.eu.github.com/
#                GITHUB_UPLOAD_URL=https://uploads.eu.github.com/
GITHUB_BASE_URL=
GITHUB_UPLOAD_URL=

# Gitea — optional; enables Gitea webhook and provider support
GITEA_URL=
GITEA_TOKEN=

# Forgejo — optional; enables Forgejo webhook and provider support
FORGEJO_URL=
FORGEJO_TOKEN=
